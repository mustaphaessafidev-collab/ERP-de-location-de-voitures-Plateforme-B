generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Review {
  id              Int      @id @default(autoincrement())
  userId          Int      // ID of the user who wrote the review
  userName        String   // Display name of the user
  userAvatar      String?  // Optional avatar URL
  carName         String   // Car model (e.g., Porsche Taycan Turbo)
  carCategory     String?  // Category (e.g., SUV, Electric)
  rating          Int      // 1-5 stars
  title           String   // Review summary title
  comment         String   @db.Text
  isVerified      Boolean  @default(true)
  helpfulCount    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("reviews")
}
