generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  userRole    String   @default("CLIENT")
  type        String
  title       String?
  message     String
  referenceId String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("notifications")
}