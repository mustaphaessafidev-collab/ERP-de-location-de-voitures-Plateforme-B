// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int       @id @default(autoincrement())
  nom_complet      String
  cin              String?   @unique   // ✅ optional
  num_permis       String?
  telephone        String?   // ✅ optional
  email            String    @unique
  adresse          String?
  profilePhotoData String?   @map("profile_photo_data")
  profilePhotoName String?   @map("profile_photo_name")
  profilePhotoMimeType String? @map("profile_photo_mime_type")
  password         String
  isEmailValidated Boolean   @default(false) @map("is_email_validated")
  created_at       DateTime  @default(now())
  updatedAt        DateTime  @updatedAt @map("updated_at")

  passwordResets           PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  drivingLicense          DrivingLicense?

  @@map("users")
}

model DrivingLicense {
  id                    Int       @id @default(autoincrement())
  userId                Int       @unique @map("user_id")
  licenseNumber         String    @map("license_number")
  expiryDate            DateTime? @map("expiry_date") @db.Date
  frontDocumentData     String?   @map("front_document_data")
  frontDocumentName     String?   @map("front_document_name")
  frontDocumentMimeType String?   @map("front_document_mime_type")
  backDocumentData      String?   @map("back_document_data")
  backDocumentName      String?   @map("back_document_name")
  backDocumentMimeType  String?   @map("back_document_mime_type")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("driving_licenses")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  email     String
  expiresAt DateTime @map("expires_at")
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  email     String
  expiresAt DateTime @map("expires_at")
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("email_verification_tokens")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Reservation {
  id             Int               @id @default(autoincrement())
  publicId       String            @unique @map("public_id")
  status         ReservationStatus @default(CONFIRMED)
  customerEmail  String            @map("customer_email")
  vehicleName    String            @map("vehicle_name")
  vehicleId      Int?              @map("vehicle_id")
  agency         String?
  city           String?
  pickUpLabel    String            @map("pick_up_label")
  returnLabel    String            @map("return_label")
  days           Int
  totalAmount    Decimal           @map("total_amount") @db.Decimal(12, 2)
  planningSlots  String?           @map("planning_slots")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@map("reservations")
}

enum NotificationType {
  success
  error
  info
  warning
}

model Notification {
  id             Int              @id @default(autoincrement())
  userEmail      String           @map("user_email")
  type           NotificationType
  title          String
  message        String
  reservationId  String?          @map("reservation_id")
  isRead         Boolean          @default(false) @map("is_read")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@map("notifications")
}
