# Copy to `.env` in this folder (auth-service root). For AWS RDS, append ?sslmode=require to DATABASE_URL.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
PORT=8000
FRONTEND_URL="http://localhost:5173"
APP_BASE_URL="http://localhost:8000"

# Email validation (set MAIL_ENABLED=true once SMTP_* are set)
MAIL_ENABLED="true"
MAIL_FROM_NAME="ERP Location"
MAIL_FROM_EMAIL="noreply.mails.dev@gmail.com"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="noreply.mails.dev@gmail.com"
SMTP_PASS="your-app-password"
